{
  "name": "stareast-commerce",
  "version": "1.0.0",
  "description": "Simple e-commerce REST API with JWT checkout flow",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node src/server.js",
    "test:path-coverage": "mocha \"test/pathCoverage/**/*.spec.js\" --reporter mochawesome --reporter-options reportDir=test-report,reportFilename=path-coverage-report,quiet=true,html=true,json=true",
    "test": "start-server-and-test start http://localhost:3000/healthcheck test:path-coverage",
    "test:load:login": "start-server-and-test start http://localhost:3000/healthcheck \"k6 run test/loadTesting/login.load.js\"",
    "test:load:login:report": "start-server-and-test start http://localhost:3000/healthcheck \"k6 run test/loadTesting/login.load.js --summary-export test-report/login-load-summary.json\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/juliodelimas/stareast-commerce.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/juliodelimas/stareast-commerce/issues"
  },
  "homepage": "https://github.com/juliodelimas/stareast-commerce#readme",
  "dependencies": {
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "swagger-ui-express": "^5.0.1",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "chai": "^6.2.2",
    "mocha": "^11.7.5",
    "mochawesome": "^7.1.4",
    "start-server-and-test": "^3.0.2",
    "supertest": "^7.2.2"
  }
}
